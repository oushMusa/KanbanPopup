<Window x:Class="KanbanPopup.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:KanbanPopup.Models"
        mc:Ignorable="d"
        Title="KanbanPopup"
        Width="980"
        Height="520"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">
    <Border CornerRadius="12" Background="#20242B" BorderBrush="#343A46" BorderThickness="1" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Height="34"
                         Padding="10,6"
                         Background="#2C313B"
                         Foreground="White"
                         BorderThickness="0"
                         Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Grid.Column="2"
                         Height="34"
                         Padding="10,6"
                         Background="#2C313B"
                         Foreground="#E0E0E0"
                         BorderThickness="0"
                         Text="{Binding NewTaskDescription, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="4"
                        Width="36"
                        Height="34"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        FontSize="20"
                        Content="+"
                        Command="{Binding AddTaskCommand}" />
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#252A33" CornerRadius="8" Padding="10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="ToDo" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ListBox ItemsSource="{Binding Columns[0].Tasks}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 AllowDrop="True"
                                 PreviewMouseLeftButtonDown="TaskCard_PreviewMouseLeftButtonDown"
                                 PreviewMouseMove="TaskCard_PreviewMouseMove"
                                 Drop="ListBox_Drop"
                                 Tag="{x:Static models:ColumnType.ToDo}">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:TaskItem}">
                                    <Border Background="#2E3440" CornerRadius="6" Margin="0,0,0,8" Padding="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Description}" Foreground="#C0C0C0" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Width="22"
                                                    Height="22"
                                                    Margin="8,0,0,0"
                                                    Content="×"
                                                    FontWeight="Bold"
                                                    Background="#4B5563"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2" Background="#252A33" CornerRadius="8" Padding="10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="InProgress" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ListBox ItemsSource="{Binding Columns[1].Tasks}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 AllowDrop="True"
                                 PreviewMouseLeftButtonDown="TaskCard_PreviewMouseLeftButtonDown"
                                 PreviewMouseMove="TaskCard_PreviewMouseMove"
                                 Drop="ListBox_Drop"
                                 Tag="{x:Static models:ColumnType.InProgress}">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:TaskItem}">
                                    <Border Background="#2E3440" CornerRadius="6" Margin="0,0,0,8" Padding="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Description}" Foreground="#C0C0C0" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Width="22"
                                                    Height="22"
                                                    Margin="8,0,0,0"
                                                    Content="×"
                                                    FontWeight="Bold"
                                                    Background="#4B5563"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <Border Grid.Column="4" Background="#252A33" CornerRadius="8" Padding="10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Done" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ListBox ItemsSource="{Binding Columns[2].Tasks}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 AllowDrop="True"
                                 PreviewMouseLeftButtonDown="TaskCard_PreviewMouseLeftButtonDown"
                                 PreviewMouseMove="TaskCard_PreviewMouseMove"
                                 Drop="ListBox_Drop"
                                 Tag="{x:Static models:ColumnType.Done}">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:TaskItem}">
                                    <Border Background="#2E3440" CornerRadius="6" Margin="0,0,0,8" Padding="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Description}" Foreground="#C0C0C0" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Width="22"
                                                    Height="22"
                                                    Margin="8,0,0,0"
                                                    Content="×"
                                                    FontWeight="Bold"
                                                    Background="#4B5563"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
